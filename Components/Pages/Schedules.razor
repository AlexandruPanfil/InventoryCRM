@page "/schedules"
@using InventoryCRM.Models
@using InventoryCRM.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject InventoryCRM.Services.ScheduleService ScheduleService
@inject InventoryCRM.Services.OrderService OrderService
@inject IAuthorizationService AuthorizationService
@attribute [Authorize]

@rendermode InteractiveServer

<PageTitle>Schedules — 15 days table</PageTitle>

<h3>Schedules — 15 days</h3>

@if (orders == null)
{
    <div class="text-center my-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!orders.Any())
{
    <div class="text-center my-4 text-muted">No orders found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table schedules-table">
            <thead>
                <tr>
                    <th class="order-col">Order</th>
                    @foreach (var day in Days)
                    {
                        <th class="day-col" title="@day.ToString("D")">
                            <div>@day.ToString("dd MMM")</div>
                            <div class="small">@day.ToString("ddd")</div>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var order in orders)
                {
                    // determine CSS class for order status
                    var statusClass = GetStatusClass(order.Status);

                    <tr>
                        <td class="order-cell">
                            <div class="fw-bold">@order.Identifier</div>
                            <div class="small">@order.Customers?.Name</div>
                        </td>

                        @foreach (var day in Days)
                        {
                            // determine schedule for this order (may come from nav prop or loaded map)
                            var sch = order.Schedule;
                            if (sch == null && order.ScheduleId.HasValue)
                            {
                                Schedule tmp;
                                orderSchedulesMap.TryGetValue(order.ScheduleId.Value, out tmp);
                                sch = tmp;
                            }

                            if (sch == null)
                            {
                                <td class="empty-cell"></td>
                            }
                            else
                            {
                                var startLocal = sch.StartTime.ToLocalTime();
                                var endLocal = sch.EndTime.ToLocalTime();

                                var dayStart = day.Date;
                                var dayEnd = day.Date.AddDays(1).AddTicks(-1);

                                // does schedule overlap the current day?
                                var overlaps = startLocal <= dayEnd && endLocal >= dayStart;

                                if (!overlaps)
                                {
                                    <td class="empty-cell"></td>
                                }
                                else
                                {
                                    string cellKindClass;
                                    if (startLocal.Date == endLocal.Date && day.Date == startLocal.Date)
                                    {
                                        cellKindClass = "schedule-single";
                                    }
                                    else if (day.Date == startLocal.Date)
                                    {
                                        cellKindClass = "schedule-start";
                                    }
                                    else if (day.Date == endLocal.Date)
                                    {
                                        cellKindClass = "schedule-end";
                                    }
                                    else
                                    {
                                        cellKindClass = "schedule-mid";
                                    }

                                    <td class="@($"{statusClass} schedule-cell {cellKindClass}")" title="@($"{startLocal:yyyy-MM-dd HH:mm} — {endLocal:yyyy-MM-dd HH:mm}")">
                                        @if (day.Date == startLocal.Date)
                                        {
                                            <div class="time-text">@startLocal.ToString("HH:mm")</div>
                                        }
                                        @if (day.Date == endLocal.Date && endLocal.Date != startLocal.Date)
                                        {
                                            <div class="time-text">@endLocal.ToString("HH:mm")</div>
                                        }
                                    </td>
                                }
                            }
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Order> orders;
    private Dictionary<Guid, Schedule> orderSchedulesMap = new();
    // show 15 days starting from today (local)
    private const int DaysCount = 15;
    private readonly List<DateTime> Days = Enumerable.Range(0, DaysCount)
        .Select(i => DateTime.Today.AddDays(i))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        orders = (await OrderService.GetAllOrdersAsync()) ?? new List<Order>();

        // collect schedule ids referenced by orders
        var scheduleIds = orders
            .Where(o => o.ScheduleId.HasValue)
            .Select(o => o.ScheduleId!.Value)
            .Distinct()
            .ToList();

        // load schedules referenced by orders (ScheduleService returns UTC stored values)
        foreach (var id in scheduleIds)
        {
            var sch = await ScheduleService.GetScheduleAsync(id);
            if (sch != null)
            {
                orderSchedulesMap[id] = sch;
            }
        }

        // if orders already include Schedule navigation, keep it; otherwise map schedules where available
        foreach (var o in orders)
        {
            if (o.Schedule == null && o.ScheduleId.HasValue && orderSchedulesMap.TryGetValue(o.ScheduleId.Value, out var loaded))
            {
                o.Schedule = loaded;
            }
        }
    }

    private string GetStatusClass(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return "status-other";

        return status switch
        {
            OrderStatus.New => "status-new",
            OrderStatus.Processing => "status-processing",
            OrderStatus.Finished => "status-finished",
            "Cancelled" => "status-cancelled",
            _ => "status-other"
        };
    }
}