@page "/orders"
@using InventoryCRM.Data
@using InventoryCRM.Models
@using InventoryCRM.Models.UnitModels
@using InventoryCRM.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@inject InventoryCRM.Services.OrderService OrderService
@inject InventoryCRM.Services.CustomerService CustomerService
@inject InventoryCRM.Services.WorkerService WorkerService
@inject InventoryCRM.Services.UnitServices.UnitService UnitService
@inject InventoryCRM.Services.UnitServices.UnitAssignmentService UnitAssignmentService
@inject InventoryCRM.Services.ScheduleService ScheduleService
@inject IAuthorizationService AuthorizationService
@rendermode InteractiveServer
@attribute [Authorize]

<PageTitle>Orders</PageTitle>
<h3>Orders</h3>

@if (!string.IsNullOrEmpty(orderConcurrencyError))
{
    <div class="alert alert-warning mb-3">
        @orderConcurrencyError
        <button class="btn btn-sm btn-secondary ms-3 text-bg-dark" @onclick="() => orderConcurrencyError = null">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>
}

<div class="mb-3">
    <div class="input-group">
        <input type="text" class="form-control" @bind="filteredName"
               placeholder="Enter the name of customer" />
        <button class="btn btn-secondary" @onclick="(FindByName)">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" margin="8" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
            </svg>
            Find Order
        </button>
        <AuthorizeView Policy="Advanced">
            <Authorized>
                <button class="btn btn-primary" @onclick="(OpenCreateForm)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-lg" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2" />
                    </svg>
                    Create Order
                </button>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@if (isFormVisible)
{
    <div class="modal-backdrop" @onclick="HandleSubmit"></div>

    <div class="centered-modal">
        <EditForm Model="newOrder" OnValidSubmit="HandleSubmit">
            <div class="mb-3">
                <h3>
                    @(CurrentMode == FormMode.Create ? "Create New Order" :
                      CurrentMode == FormMode.Update ? "Edit Order" : "View Order")
                </h3>

                @if (CurrentMode == FormMode.Create)
                {
                    <button class="btn btn-primary" type="button" @onclick="CreateOrder">Save</button>
                    <button class="btn btn-secondary" type="button" @onclick="() => isSecondFormVisible = true">Add Unit</button>
                }
                else if (IsEditable && newOrder.Status == "New")
                {
                    <button class="btn btn-primary" type="button" @onclick="UpdateOrder">
                        <i class="bi bi-gear-wide"></i>
                        <span>Update</span>
                    </button>

                    <button class="btn btn-primary" type="button" @onclick="OrderProcesing">
                        <i class="bi bi-gear-wide"></i>
                        <span>To Process</span>
                    </button>

                    <button class="btn btn-secondary" type="button" @onclick="() => isSecondFormVisible = true">Add Unit</button>

                } 
                else if (newOrder.Status == "Processing")
                {
                    <button class="btn btn-primary" type="button" @onclick="OrderProcesing" disabled="@( !CanCompleteOrder )" title="@(CanCompleteOrder ? string.Empty : "Assign a worker with a deposit to complete the order")">
                        <i class="bi bi-check-lg"></i>
                        <span>Complete Order</span>
                    </button>
                }
                else
                {
                    <button class="btn btn-primary" type="button" @onclick="OrderProcesing" disabled>
                        <i class="bi bi-check-all"></i>
                        <span>Order Completed</span>
                    </button>
                }

            </div>
            <button class="btn-close btn-close-black position-absolute top-0 end-0 m-3" aria-label="Close" @onclick="HandleSubmit"></button>
            <div>
                <div class="mb-2">Customer</div>
                <InputSelect @bind-Value="selectedCustomer" class="form-control" disabled="@IsReadOnly">
                    <option value="">Select Customer</option>
                    @foreach (var customer in customers)
                    {
                        <option value="@customer.Id">@customer.Name - @customer.Id</option>
                    }
                </InputSelect>
            </div>
            <div>
                <div class="mb-2">Worker</div>
                <InputSelect @bind-Value="selectedWorker" class="form-control" disabled="@IsReadOnly">
                    <option value="">Select Worker</option>
                    @foreach (var worker in workers)
                    {
                        <option value="@worker.Id">@worker.Workername - @worker.Id</option>
                    }
                </InputSelect>
            </div>

            <div>
                <div class="mb-2">Schedule</div>
                <InputSelect @bind-Value="selectedSchedule" class="form-control" disabled="@IsReadOnly">
                    <option value="">No schedule</option>
                    @foreach (var sch in schedules)
                    {
                        <option value="@sch.Id">@sch.StartTime.ToLocalTime().ToString("g") - @sch.EndTime.ToLocalTime().ToString("g")</option>
                    }
                </InputSelect>
            </div>
            <div>
                <div class="mb-2">Description:</div>
                <InputText @bind-Value="newDescription" class="form-control" readonly="@IsReadOnly" />
            </div>
            <div class="list-group">
                @if (selectedUnits == null)
                {
                    <span> No Units Added</span>
                }
                else if (selectedUnits.Count == 0)
                {
                    <span> No Units Added</span>
                }
                else
                {
                    foreach (var unit in selectedUnits)
                    {
                        <div class="list-group-item  justify-content-between align-items-center">
                            <div class="unit-list-item row g-3">
                                <span class="me-3 col-4"><strong>Unit Name:</strong> @unit.Name</span>
                                <span class="me-3 col-4"><strong>Unit Quantity:</strong> @unit.Quantity</span>
                                @if (ShowActions)
                                {
                                    <button class="btn btn-danger col-1" type="button" @onclick="() => selectedUnits.Remove(unit)">Remove</button>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </EditForm>
    </div>
}


@if (isSecondFormVisible)
{
    <div class="modal-second-backdrop" @onclick="() => isSecondFormVisible = false"></div>

    <div class="centered-second-modal">
        <EditForm Model="newUnit" OnValidSubmit="ConvertUnitsToList">
            <div class="mb-3">
                <h3>Move Unit</h3>
                <button class="btn btn-primary" type="submit">Save</button>
            </div>
            <button class="btn-close btn-close-black position-absolute top-0 end-0 m-3" aria-label="Close" @onclick="() => isSecondFormVisible = false"></button>
            <div>
                <div class="mb-2">Unit:</div>
                <InputSelect @bind-Value="unitID" class="form-control">
                    <option value="">Select Unit</option>
                    @foreach (var unit in units)
                    {
                        <option value="@unit.Id">@unit.Name - @unit.Quantity</option>
                    }
                </InputSelect>
            </div>
            <div>
                <div class="mb-2">Quantity:</div>
                <InputNumber @bind-Value="unitQuantity" class="form-control" />
            </div>
        </EditForm>
    </div>
}


@if (orders == null)
{
    <div class="text-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p><em>Loading customers...</em></p>
    </div>
}
else if (orders.Count == 0)
{
    <div class="text-center">
        <p><em>There is no customers, You can create a new one</em></p>
    </div>
}
else
{
    <div class="list-group shadow-sm">
        @foreach (var order in orders)
        {
            <div class="list-group-item list-group-item-action py-3" @onclick="() => OpenOrder(order)" style="cursor:pointer">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span>
                        <strong class="text-primary">@order.Status @order.Identifier :</strong>
                        <span class="fw-bold ms-1">@order.Customers?.Name</span>
                    </span>
                    <small class="text-muted">@order.UpdatedAt.ToString("g")</small>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <span class="small text-secondary">
                            <i class="bi bi-person me-1"></i>
                            <strong>Worker:</strong>
                            @(order.Worker?.Workername ?? "No Worker Assigned")
                    </span>

                    @if (!string.IsNullOrEmpty(order.Description))
                    {
                        <small class="text-muted text-truncate ms-3" style="max-width: 50%;">
                            @order.Description
                        </small>
                    }
                </div>
            </div>
        }
    </div>
}




@code {
    [CascadingParameter] private Task<AuthenticationState> authenticationStateTask { get; set; }
    private List<Order> orders;

    private Order newOrder = new Order();
    private string newDescription = string.Empty;

    private List<Customer> customers = new List<Customer>();
    private string selectedCustomer = string.Empty;

    private List<Worker> workers = new List<Worker>();
    private string selectedWorker  = string.Empty;

    private List<Unit> units = new List<Unit>();
    private List<UnitAssignment> selectedUnits = new List<UnitAssignment>();
    private UnitAssignment newUnit = new UnitAssignment();
    private Guid unitID = Guid.Empty;
    private string unitName = string.Empty;
    private int unitQuantity = 0;
    private static readonly Guid unitDefaultDepositId = Guid.Parse("00000000-0000-0000-0000-000000000001");
    private List<Schedule> schedules = new List<Schedule>();
    private string selectedSchedule = string.Empty;

    public enum FormMode { Create, Update, ReadOnly }

    [Parameter] public FormMode CurrentMode { get; set; } = FormMode.Create;

    bool IsReadOnly => CurrentMode == FormMode.ReadOnly;
    bool IsEditable => CurrentMode == FormMode.Update;
    bool ShowActions => CurrentMode != FormMode.ReadOnly;

    private string filteredName = string.Empty;
    private bool isFormVisible = false;
    private bool isSecondFormVisible = false;
    private bool isSubmitting = false;

    private bool advanced = false;
    private string? orderConcurrencyError;

    private bool CanCompleteOrder =>
        newOrder != null
        && newOrder.WorkerId.HasValue
        && workers.Any(w => w.Id == newOrder.WorkerId.Value && w.Deposit != null);

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
        var authState = await authenticationStateTask;
        advanced = (await AuthorizationService.AuthorizeAsync(authState.User, "Advanced")).Succeeded;
    }

    private async Task LoadOrders()
    {
        orders = await OrderService.GetAllOrdersAsync();
        units = await UnitService.GetAllUnitsAsync();
        workers = await WorkerService.GetAllUsersAsync();
        customers = await CustomerService.GetAllCustomersAsync();
        schedules = await ScheduleService.GetAllSchedulesAsync();
    }

    private async Task FindByName()
    {
        if (string.IsNullOrWhiteSpace(filteredName))
        {
            await LoadOrders();
        }
        else
        {
            orders = await OrderService.FindOrdersByCustomerNameAsync(filteredName);
        }
    }

    private async Task CreateOrder()
    {
        newOrder.Description = newDescription;

        if (Guid.TryParse(selectedCustomer, out var customerId))
        {
            newOrder.CustomersId = customerId;
        }

        if (Guid.TryParse(selectedSchedule, out var scheduleId))
        {
            newOrder.ScheduleId = scheduleId;
        }

        newOrder.UnitAssignment = selectedUnits;
        newOrder.CreatedAt = DateTime.UtcNow;
        newOrder.UpdatedAt = DateTime.UtcNow;
        newOrder.WorkerId = Guid.TryParse(selectedWorker, out var workerId) ? workerId : (Guid?)null;

        await OrderService.CreateOrderAsync(newOrder);

        await HandleSubmit();
    }

    private void ConvertUnitsToList()
    {
        if (selectedUnits == null) selectedUnits = new List<UnitAssignment>();

        if(Guid.TryParse(selectedCustomer, out var customerId)){

            var unitToTransfer = units.FirstOrDefault(u => u.Id == unitID);

            selectedUnits.Add(new UnitAssignment
            {
                //ChatGPT
                Id = Guid.Empty,
                // Gemini
                // Id = Guid.NewGuid(),
                Name = unitToTransfer.Name,
                Quantity = unitQuantity,
                CustomerId = customerId
            });
        }

        unitID = Guid.Empty;
        unitName = string.Empty;
        unitQuantity = 0;
        isSecondFormVisible = false;
    }

    private async Task UpdateOrder()
    {
        if (isSubmitting) return;
        isSubmitting = true;

        try{
            await OrderService.UpdateOrderAsync(newOrder.Id, newDescription, null, selectedUnits, selectedCustomer, selectedWorker, selectedSchedule);
            orderConcurrencyError = null;
            await HandleSubmit();
        }
        catch (DbUpdateConcurrencyException)
        {
            orderConcurrencyError = "The order was modified by another user. Please reload and try again.";
            await LoadOrders();
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void OpenOrder(Order order)
    {
        if (order.Status == OrderStatus.Finished || order.Status == OrderStatus.Processing)
        {
            CurrentMode = FormMode.ReadOnly;
        }
        else
        {
            CurrentMode = FormMode.Update;
        }
        newOrder = order;
        isFormVisible = true;

        selectedCustomer = newOrder.CustomersId.ToString();
        selectedUnits = order.UnitAssignment?.Select(u => new UnitAssignment {
            Id = u.Id,
            Name = u.Name,
            Quantity = u.Quantity,
            CustomerId = u.CustomerId,
            }).ToList() ?? new List<UnitAssignment>();

        selectedWorker = newOrder.WorkerId?.ToString() ?? string.Empty;
        selectedSchedule = newOrder.ScheduleId?.ToString() ?? string.Empty;
        newDescription = newOrder.Description;
    }

    private async Task HandleSubmit()
    {
        isFormVisible = false;
        isSubmitting = false;

        newOrder = new Order();
        selectedUnits = new List<UnitAssignment>();
        selectedCustomer = string.Empty;
        selectedWorker = string.Empty;
        selectedSchedule = string.Empty;
        newDescription = string.Empty;

        await LoadOrders();
        StateHasChanged();
    }

    private async Task OrderProcesing()
    {
        // If order is New -> move to Processing
        if (newOrder.Status == OrderStatus.New)
        {
            newOrder.SetStatus(OrderStatus.Processing);
            await OrderService.UpdateOrderAsync(newOrder.Id, null, OrderStatus.Processing);
            await LoadOrders();
            return;
        }

        // Only proceed to complete if order is Processing
        if (newOrder.Status != OrderStatus.Processing)
            return;

        var orderToComplete = await OrderService.GetOrderAsync(newOrder.Id);
        if (orderToComplete == null)
        {
            orderConcurrencyError = "Order not found.";
            StateHasChanged();
            return;
        }

        // Validate worker assigned
        if (!orderToComplete.WorkerId.HasValue)
        {
            orderConcurrencyError = "Cannot complete order: no worker assigned.";
            StateHasChanged();
            return;
        }

        var worker = workers.FirstOrDefault(w => w.Id == orderToComplete.WorkerId.Value);
        if (worker == null)
        {
            orderConcurrencyError = "Cannot complete order: assigned worker not found in the UI.";
            StateHasChanged();
            return;
        }

        if (worker.Deposit == null)
        {
            orderConcurrencyError = "Cannot complete order: assigned worker has no deposit.";
            StateHasChanged();
            return;
        }

        var workerUnits = (await UnitService.GetAllUnitsAsync())
            .Where(u => u.DepositId == worker.Deposit.Id)
            .ToList();

        var orderUnits = orderToComplete.UnitAssignment?.ToList() ?? new List<UnitAssignment>();

        // Ensure stock sufficiency
        foreach (var orderUnit in orderUnits)
        {
            var workerUnit = workerUnits.FirstOrDefault(u => u.Name == orderUnit.Name);
            if (workerUnit == null || workerUnit.Quantity < orderUnit.Quantity)
            {
                orderConcurrencyError = $"Cannot complete order: insufficient '{orderUnit.Name}' in worker deposit.";
                StateHasChanged();
                return;
            }
        }

        // Perform stock updates and mark assignments installed
        foreach (var orderUnit in orderUnits)
        {
            var workerUnit = workerUnits.First(u => u.Name == orderUnit.Name);
            var remainingQuantity = workerUnit.Quantity - orderUnit.Quantity;

            if (remainingQuantity <= 0)
            {
                await UnitService.DeleteUnitAsync(workerUnit.Id);
            }
            else
            {
                await UnitService.UpdateUnitAsync(workerUnit.Id, workerUnit.Name, remainingQuantity);
            }

            await UnitAssignmentService.UpdateUnitReservedAsync(orderUnit.Id, orderUnit.Name, orderUnit.Quantity, UnitStatus.Installed);
        }

        orderToComplete.SetStatus(OrderStatus.Finished);
        await OrderService.UpdateOrderAsync(orderToComplete.Id, null,OrderStatus.Finished);

        newOrder = orderToComplete;
        await LoadOrders();
    }

    private void OpenCreateForm(){
        isFormVisible = true;
        CurrentMode = FormMode.Create;
    }
}


